{
  "name": "@webdock/sdk",
  "version": "1.0.59695",
  "homepage": "https://github.com/webdock-io/nodejs-sdk#readme",
  "description": "SDK for Webdock's API",
  "exports": {
    ".": {
      "types": "./dist/index.d",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "test": "jest --runInBand",
    "publish:npm": "npm run build && npm publish"
  },
  "keywords": [
    "sdk",
    "api",
    "webdock",
    "node"
  ],
  "author": {
    "name": "Ahmad Addel",
    "email": "a4amado@gmail.com",
    "url": "https://www.linkedin.com/in/a4amado/"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "tslib": "^2.8.1",
    "webdock": "^2.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.130",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "ajv": ">=8.18.0",
      "handlebars": ">=4.7.9",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5"
    }
  }
}